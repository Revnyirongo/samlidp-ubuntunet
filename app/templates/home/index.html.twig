<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UbuntuNet Access Hub</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ubuntu: {
                            50: '#fbefe7',
                            100: '#f6dcc8',
                            500: '#d96a2e',
                            600: '#bf5720'
                        },
                        idp: {
                            50: '#eef4fb',
                            100: '#d8e7f6',
                            500: '#1f5f97',
                            600: '#174d7d',
                            700: '#103857'
                        }
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --page-bg:
                radial-gradient(circle at top left, rgba(217, 106, 46, 0.14), transparent 24rem),
                radial-gradient(circle at top right, rgba(31, 95, 151, 0.14), transparent 26rem),
                linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        }

        body {
            font-family: 'Manrope', sans-serif;
            background: var(--page-bg);
        }
    </style>
</head>
<body class="min-h-full text-slate-900">
    <main class="mx-auto max-w-7xl px-4 py-5 sm:px-6 lg:px-8">
        <header class="sticky top-4 z-20 rounded-[2rem] border border-slate-200/70 bg-white/86 px-5 py-4 shadow-[0_25px_60px_rgba(15,23,42,0.08)] backdrop-blur">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
                <div class="flex items-center gap-4">
                    <div class="flex h-14 w-14 items-center justify-center rounded-3xl bg-gradient-to-br from-ubuntu-500 to-idp-600 text-lg font-extrabold text-white shadow-sm">U</div>
                    <div>
                        <div class="text-xs font-extrabold uppercase tracking-[0.22em] text-slate-400">UbuntuNet Alliance</div>
                        <div class="flex flex-wrap items-center gap-2">
                            <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">UbuntuNet Access Hub</h1>
                            <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-extrabold uppercase tracking-[0.16em] text-slate-500">v{{ app_version() }}</span>
                        </div>
                    </div>
                </div>
                <nav class="flex flex-wrap items-center gap-2 text-sm font-semibold text-slate-600">
                    <a href="/" class="rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900">Overview</a>
                    <a href="/login" class="rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900">Tenants</a>
                    <a href="/login" class="rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900">Federations</a>
                    <a href="/login" class="rounded-full px-4 py-2 transition hover:bg-slate-100 hover:text-slate-900">Service Providers</a>
                    <a href="{{ docs_url }}" target="_blank" rel="noopener" class="rounded-full border border-slate-300 px-4 py-2 text-slate-700 transition hover:bg-slate-50">Documentation</a>
                    <a href="/login" class="rounded-full bg-idp-600 px-5 py-2.5 text-white transition hover:bg-idp-500">Login</a>
                </nav>
            </div>
        </header>

        {% if not mailer_enabled %}
        <section class="mt-6 rounded-2xl border border-amber-200 bg-amber-50 px-5 py-4 text-sm text-amber-800">
            Email delivery is not configured yet. Configure <code>MAILER_DSN</code>, <code>MAILER_FROM_ADDRESS</code>, and <code>MAILER_FROM_NAME</code> in <code>.env</code> before enabling password recovery and self-service onboarding in production.
        </section>
        {% endif %}

        <section class="mt-6 overflow-hidden rounded-[2.5rem] border border-slate-200/70 bg-slate-950 text-white shadow-[0_35px_80px_rgba(15,23,42,0.12)]">
            <div class="grid gap-8 px-6 py-8 sm:px-8 sm:py-10 lg:grid-cols-[1.02fr_0.98fr] lg:px-10">
                <div class="flex flex-col justify-between">
                    <div>
                        <div class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-white/70">
                            Managed identity for higher education and research
                        </div>
                        <h2 class="mt-6 max-w-3xl text-4xl font-extrabold tracking-tight sm:text-5xl">
                            Launch a standards-ready institutional IdP without building the stack from scratch.
                        </h2>
                        <p class="mt-5 max-w-2xl text-sm leading-7 text-white/72 sm:text-base">
                            UbuntuNet Access Hub packages tenant branding, metadata generation, service provider onboarding, account lifecycle, attribute release, and federation operations into one deployable platform built for institutional rollouts across Africa.
                        </p>
                    </div>
                    <div class="mt-8 flex flex-wrap gap-3">
                        <a href="/login" class="rounded-2xl bg-white px-5 py-3 text-sm font-bold text-slate-900 transition hover:bg-slate-100">Open Admin Console</a>
                        <a href="{{ docs_url }}" target="_blank" rel="noopener" class="rounded-2xl border border-white/20 px-5 py-3 text-sm font-bold text-white transition hover:bg-white/10">Read Deployment Docs</a>
                        <a href="/login" class="rounded-2xl border border-white/20 px-5 py-3 text-sm font-bold text-white transition hover:bg-white/10">View Federations</a>
                    </div>
                    <dl class="mt-8 grid gap-3 sm:grid-cols-3">
                        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                            <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-white/55">Backends</dt>
                            <dd class="mt-2 text-sm font-semibold text-white">LDAP, SQL, SAML, RADIUS</dd>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                            <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-white/55">Federation</dt>
                            <dd class="mt-2 text-sm font-semibold text-white">Rich IdP metadata and SP onboarding</dd>
                        </div>
                        <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                            <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-white/55">Operations</dt>
                            <dd class="mt-2 text-sm font-semibold text-white">Containerized deployment and admin workflows</dd>
                        </div>
                    </dl>
                </div>

                <div class="flex items-center justify-center">
                    <div class="w-full max-w-2xl rounded-[2rem] border border-white/10 bg-white/6 p-4 shadow-[0_20px_50px_rgba(15,23,42,0.25)] backdrop-blur">
                        <img src="/assets/access-hub-hero.svg" alt="UbuntuNet Access Hub platform illustration" class="w-full rounded-[1.5rem]">
                    </div>
                </div>
            </div>
        </section>

        <section class="mt-6 grid gap-4 lg:grid-cols-[0.9fr_1.1fr]">
            <div class="rounded-[2rem] border border-slate-200/70 bg-white/92 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)]">
                <div class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-400">What is included</div>
                <ul class="mt-4 space-y-3 text-sm leading-6 text-slate-600">
                    <li>Institution-scoped tenant IdPs with branding, contacts, and federation publication controls.</li>
                    <li>Service provider metadata import, approval, requested-attribute review, and release policy management.</li>
                    <li>Self-service account registration, invitations, password reset, and tenant-admin approval workflows.</li>
                    <li>eduroam authentication onboarding for supported backends, alongside federation and metadata automation.</li>
                </ul>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
                <article class="rounded-[2rem] border border-slate-200/70 bg-white/92 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)]">
                    <div class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-400">Built with</div>
                    <h3 class="mt-3 text-lg font-extrabold tracking-tight text-slate-900">Operational stack</h3>
                    <p class="mt-2 text-sm leading-6 text-slate-600">Symfony, SimpleSAMLphp, PostgreSQL, Redis, and Docker-based deployment with generated per-tenant configuration.</p>
                </article>
                <article class="rounded-[2rem] border border-slate-200/70 bg-white/92 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)]">
                    <div class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-400">Documentation</div>
                    <h3 class="mt-3 text-lg font-extrabold tracking-tight text-slate-900">Rollout guidance</h3>
                    <p class="mt-2 text-sm leading-6 text-slate-600">Deployment notes, federation practices, and operating procedures are intended to live on GitLab for institutional teams.</p>
                </article>
                <article class="rounded-[2rem] border border-slate-200/70 bg-white/92 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)] md:col-span-2">
                    <div class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-400">Common next steps</div>
                    <div class="mt-4 grid gap-3 sm:grid-cols-3">
                        <a href="/login" class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-idp-500 hover:text-idp-600">Review tenants and IdPs</a>
                        <a href="/login" class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-idp-500 hover:text-idp-600">Manage federations</a>
                        <a href="{{ docs_url }}" target="_blank" rel="noopener" class="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:border-idp-500 hover:text-idp-600">Open documentation</a>
                    </div>
                    <p class="mt-4 text-xs leading-5 text-slate-500">Administrative and operational screens require sign-in. Public visitors are redirected to login when they try to access protected areas.</p>
                </article>
            </div>
        </section>

        <section class="mt-6 rounded-[2rem] border border-slate-200/70 bg-white/92 p-6 shadow-[0_20px_45px_rgba(15,23,42,0.06)]">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
                <div>
                    <div class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-400">Platform posture</div>
                    <h3 class="mt-2 text-2xl font-extrabold tracking-tight text-slate-900">Made for repeatable institutional deployment</h3>
                </div>
                <a href="/login" class="rounded-2xl bg-idp-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-idp-500">Launch the platform</a>
            </div>
            <div class="mt-5 grid gap-4 lg:grid-cols-4">
                <div class="rounded-2xl bg-slate-50 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">Federation</div>
                    <p class="mt-2 text-sm text-slate-600">Metadata publication, discovery support, and federation export.</p>
                </div>
                <div class="rounded-2xl bg-slate-50 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">Identity lifecycle</div>
                    <p class="mt-2 text-sm text-slate-600">Invites, password reset, self-registration, and tenant approval workflows.</p>
                </div>
                <div class="rounded-2xl bg-slate-50 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">Attribute control</div>
                    <p class="mt-2 text-sm text-slate-600">Tenant defaults and per-service-provider release decisions.</p>
                </div>
                <div class="rounded-2xl bg-slate-50 px-4 py-4">
                    <div class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-400">Operations</div>
                    <p class="mt-2 text-sm text-slate-600">Structured errors, request IDs, and documented deployment paths.</p>
                </div>
            </div>
        </section>

        <footer class="mt-6 flex flex-col gap-2 px-1 pb-6 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between">
            <div>UbuntuNet Access Hub v{{ app_version() }}</div>
            <div>Production release for managed federated identity operations.</div>
        </footer>
    </main>
</body>
</html>
