{% extends 'admin/base.html.twig' %}
{% block page_title %}Admin Users{% endblock %}

{% block top_actions %}
<a href="{{ path('admin_user_new') }}"
   class="inline-flex items-center gap-2 px-4 py-2 bg-idp-500 hover:bg-idp-600 text-white rounded-lg text-sm font-medium">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
    </svg>
    New User
</a>
{% endblock %}

{% block content %}
<form method="get" class="flex items-center gap-3 mb-6">
    <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" value="{{ q }}" placeholder="Search by name or email…"
               class="w-full pl-9 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
    </div>
    <button type="submit" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-gray-50">Filter</button>
</form>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    {% if pagination.totalItemCount == 0 %}
    <div class="px-6 py-12 text-center text-gray-400 text-sm">No users found.</div>
    {% else %}
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">User</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Role</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Last login</th>
                <th class="px-5 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for user in pagination %}
            <tr class="hover:bg-gray-50">
                <td class="px-5 py-3.5">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-full bg-idp-100 text-idp-700 flex items-center justify-center font-semibold text-sm">
                            {{ user.fullName|first|upper }}
                        </div>
                        <div>
                            <div class="font-medium text-gray-900">{{ user.fullName }}</div>
                            <div class="text-xs text-gray-400">{{ user.email }}</div>
                        </div>
                    </div>
                </td>
                <td class="px-5 py-3.5">
                    <span class="inline-flex px-2 py-0.5 rounded text-xs font-medium
                        {{ 'ROLE_SUPER_ADMIN' in user.roles ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' }}">
                        {{ 'ROLE_SUPER_ADMIN' in user.roles ? 'Super Admin' : 'Admin' }}
                    </span>
                </td>
                <td class="px-5 py-3.5">
                    {% if user.active %}
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Active
                        </span>
                    {% else %}
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                            <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Inactive
                        </span>
                    {% endif %}
                </td>
                <td class="px-5 py-3.5 text-xs text-gray-400">
                    {{ user.lastLoginAt ? user.lastLoginAt|date('Y-m-d H:i') : 'Never' }}
                </td>
                <td class="px-5 py-3.5 text-right">
                    <div class="flex items-center justify-end gap-2">
                        <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                           class="text-xs text-idp-600 hover:underline">Edit</a>

                        {% if user != app.user %}
                        <form action="{{ path('admin_user_toggle_active', {id: user.id}) }}" method="post" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle-' ~ user.id) }}">
                            <button type="submit"
                                    class="text-xs {{ user.active ? 'text-red-500 hover:text-red-700' : 'text-green-600 hover:text-green-800' }}">
                                {{ user.active ? 'Deactivate' : 'Activate' }}
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}
</div>
{% endblock %}
