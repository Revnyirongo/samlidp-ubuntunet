{% extends 'admin/base.html.twig' %}

{% block page_title %}Dashboard{% endblock %}

{% block content %}
{# ── Stats grid ────────────────────────────────────────────── #}
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    {% set stats = [
        {label: 'Active Tenants',  value: statusCounts.active ?? 0,    color: 'green',  icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4'},
        {label: 'Pending',         value: statusCounts.pending ?? 0,   color: 'amber',  icon: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'},
        {label: 'Suspended',       value: statusCounts.suspended ?? 0, color: 'red',    icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636'},
        {label: 'Total SPs',       value: totalSps,                    color: 'blue',   icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01'},
    ] %}
    {% for stat in stats %}
    <div class="bg-white rounded-xl border border-gray-200 p-5">
        <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-medium text-gray-500">{{ stat.label }}</span>
            <div class="w-8 h-8 bg-{{ stat.color }}-50 rounded-lg flex items-center justify-center">
                <svg class="w-4 h-4 text-{{ stat.color }}-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="{{ stat.icon }}"/>
                </svg>
            </div>
        </div>
        <div class="text-3xl font-bold text-gray-900">{{ stat.value }}</div>
    </div>
    {% endfor %}
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {# ── Recent tenants ─────────────────────────────────────── #}
    <div class="bg-white rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
            <h2 class="text-sm font-semibold text-gray-900">Recent Tenants</h2>
            <a href="{{ path('admin_tenant_index') }}" class="text-xs text-idp-600 hover:underline">
                {{ is_granted('ROLE_SUPER_ADMIN') ? 'View all' : 'Open list' }}
            </a>
        </div>
        <div class="divide-y divide-gray-50">
            {% for tenant in recentTenants %}
            <a href="{{ path('admin_tenant_show', {id: tenant.id}) }}"
               class="flex items-center gap-4 px-6 py-3 hover:bg-gray-50">
                <div class="w-8 h-8 bg-idp-50 text-idp-600 rounded-lg flex items-center justify-center text-sm font-bold flex-shrink-0">
                    {{ tenant.slug|first|upper }}
                </div>
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-gray-900 truncate">{{ tenant.name }}</div>
                    <div class="text-xs text-gray-400">{{ tenant.slug }}.{{ app.request.host }}</div>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-full
                    {{ tenant.status == 'active' ? 'bg-green-100 text-green-700' :
                       tenant.status == 'pending' ? 'bg-amber-100 text-amber-700' :
                       'bg-red-100 text-red-700' }}">
                    {{ tenant.status }}
                </span>
            </a>
            {% else %}
            <p class="px-6 py-8 text-sm text-gray-400 text-center">No tenants yet.</p>
            {% endfor %}
        </div>
    </div>

    {# ── Expiring SP certs ──────────────────────────────────── #}
    <div class="bg-white rounded-xl border border-gray-200">
        <div class="px-6 py-4 border-b border-gray-100">
            <h2 class="text-sm font-semibold text-gray-900">Expiring SP Certificates</h2>
        </div>
        <div class="divide-y divide-gray-50">
            {% for sp in expiringSps %}
            <div class="px-6 py-3 flex items-center gap-3">
                <div class="flex-1 min-w-0">
                    <div class="text-sm font-medium text-gray-800 truncate">{{ sp.displayName }}</div>
                    <div class="text-xs text-gray-400 truncate">{{ sp.tenant.name }}</div>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-full
                    {{ sp.certificateExpiresAt < date('+7 days') ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' }}">
                    {{ sp.certificateExpiresAt|date('Y-m-d') }}
                </span>
            </div>
            {% else %}
            <div class="px-6 py-8 text-center">
                <svg class="w-8 h-8 text-green-400 mx-auto mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                <p class="text-sm text-gray-400">All SP certificates are valid.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
