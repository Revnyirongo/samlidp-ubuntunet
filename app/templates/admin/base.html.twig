<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex,nofollow">
    <title>{% block title %}UbuntuNet IdP Admin{% endblock %}</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ubuntu: {
                            50: '#fbefe7',
                            100: '#f6dcc8',
                            500: '#d96a2e',
                            600: '#bf5720',
                        },
                        idp: {
                            50: '#eef4fb',
                            100: '#d8e7f6',
                            500: '#1f5f97',
                            600: '#174d7d',
                            700: '#103857',
                        }
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --app-bg: #eef2f7;
            --panel: rgba(255, 255, 255, 0.82);
            --panel-border: rgba(148, 163, 184, 0.22);
            --sidebar-text: #475569;
            --sidebar-active: #103857;
        }

        body {
            font-family: 'Manrope', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(217, 106, 46, 0.10), transparent 26rem),
                radial-gradient(circle at top right, rgba(31, 95, 151, 0.10), transparent 28rem),
                linear-gradient(180deg, #f8fafc 0%, var(--app-bg) 100%);
            color: #0f172a;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.8rem 0.95rem;
            border-radius: 1rem;
            font-size: 0.92rem;
            font-weight: 700;
            color: var(--sidebar-text);
            transition: background-color 160ms ease, color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
        }

        .sidebar-link.active {
            background: var(--sidebar-active);
            color: #fff;
            box-shadow: 0 14px 30px rgba(16, 56, 87, 0.18);
        }

        .sidebar-link:not(.active):hover {
            background: rgba(255, 255, 255, 0.88);
            color: #0f172a;
            transform: translateX(1px);
        }
    </style>
    {% block head_extra %}{% endblock %}
</head>
<body class="h-full">
<div class="min-h-full lg:flex">
    <aside class="w-full shrink-0 border-b border-slate-200/70 bg-white/86 backdrop-blur lg:sticky lg:top-0 lg:h-screen lg:w-72 lg:border-b-0 lg:border-r">
        <div class="flex items-center gap-3 border-b border-slate-200/70 px-6 py-6">
            <div class="flex h-11 w-11 items-center justify-center overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
                <img src="/assets/default-security-shield.svg" alt="Security shield" class="h-full w-full object-contain p-1.5">
            </div>
            <div>
                <div class="text-sm font-extrabold tracking-tight text-slate-900">UbuntuNet Managed IdP</div>
                <div class="text-xs font-medium text-slate-500">Administration</div>
            </div>
        </div>

        <nav class="space-y-1 px-4 py-5 lg:space-y-1.5">
            <a href="{{ path('admin_dashboard') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 13h6V5H4v8zm0 6h6v-4H4v4zm10 0h6V11h-6v8zm0-14v4h6V5h-6z"/></svg>
                Dashboard
            </a>

            <div class="px-3 pt-5 pb-1 text-[11px] font-extrabold uppercase tracking-[0.18em] text-slate-400">Tenants</div>

            <a href="{{ path('admin_tenant_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'admin_tenant_' ? 'active' : '' }}">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M6 18V7m6 11V4m6 14v-8M4 7h16"/></svg>
                {{ is_granted('ROLE_SUPER_ADMIN') ? 'All Tenants' : 'My Tenants' }}
            </a>

            {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a href="{{ path('admin_tenant_new') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') == 'admin_tenant_new' ? 'active' : '' }}">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14m7-7H5"/></svg>
                New Tenant
            </a>
            {% endif %}

            <div class="px-3 pt-5 pb-1 text-[11px] font-extrabold uppercase tracking-[0.18em] text-slate-400">System</div>

            {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a href="{{ path('admin_user_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'admin_user_' ? 'active' : '' }}">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-1a4 4 0 00-4-4H6a4 4 0 00-4 4v1h5m4 0h2m-1-8a4 4 0 100-8 4 4 0 000 8z"/></svg>
                Admin Users
            </a>
            {% endif %}

            {% if is_granted('ROLE_SUPER_ADMIN') %}
            <a href="{{ path('admin_registration_request_index') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') starts with 'admin_registration_request_' ? 'active' : '' }}">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h8m-8 4h5m-7 7h12a2 2 0 002-2V7l-4-4H6a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
                Access Requests
            </a>
            {% endif %}

            <a href="{{ path('admin_audit_log') }}"
               class="sidebar-link {{ app.request.attributes.get('_route') == 'admin_audit_log' ? 'active' : '' }}">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6M8 4h8l4 4v12H4V4h4z"/></svg>
                Audit Log
            </a>
        </nav>

        <div class="border-t border-slate-200/70 px-4 py-4">
            <div class="rounded-2xl border border-slate-200/70 bg-slate-50/90 px-3.5 py-3">
                <div class="flex items-center gap-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-2xl bg-idp-600 text-sm font-bold text-white">
                        {{ app.user.fullName|first|upper }}
                    </div>
                    <div class="min-w-0 flex-1">
                        <div class="truncate text-sm font-semibold text-slate-900">{{ app.user.fullName }}</div>
                        <div class="truncate text-xs text-slate-500">{{ app.user.email }}</div>
                    </div>
                    <form action="{{ path('app_logout') }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('logout') }}">
                        <button type="submit" class="rounded-xl p-2 text-slate-400 transition hover:bg-white hover:text-slate-700" title="Logout">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H9m4 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        </button>
                    </form>
                </div>
            </div>
            <div class="mt-3 px-1 text-xs font-medium text-slate-500">Version {{ app_version() }}</div>
        </div>
    </aside>

    <main class="min-w-0 flex-1 overflow-y-auto">
        <div class="sticky top-0 z-10 border-b border-slate-200/70 bg-white/78 backdrop-blur">
            <div class="mx-auto flex max-w-7xl items-start justify-between gap-4 px-6 py-5 lg:px-10">
                <div>
                    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">{% block page_title %}Dashboard{% endblock %}</h1>
                    {% block breadcrumb %}{% endblock %}
                </div>
                <div class="flex items-center gap-3">
                    {% block top_actions %}{% endblock %}
                </div>
            </div>
        </div>

        <div class="mx-auto max-w-7xl px-6 pt-5 lg:px-10">
            {% for type, messages in app.flashes %}
                {% set colorMap = {'success': 'green', 'danger': 'red', 'warning': 'amber', 'info': 'blue'} %}
                {% set color = colorMap[type] ?? 'gray' %}
                {% for message in messages %}
                <div class="mb-3 flex items-start gap-3 rounded-2xl border border-{{ color }}-200 bg-{{ color }}-50/90 px-4 py-3 text-sm text-{{ color }}-800 shadow-sm">
                    <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-{{ color }}-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        {% if type == 'success' %}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        {% elseif type == 'danger' %}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        {% else %}<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>{% endif %}
                    </svg>
                    <span>{{ message }}</span>
                </div>
                {% endfor %}
            {% endfor %}
        </div>

        <div class="mx-auto max-w-7xl px-6 py-6 lg:px-10 lg:py-8">
            {% block content %}{% endblock %}
        </div>

        <div class="mx-auto max-w-7xl px-6 pb-6 text-xs text-slate-500 lg:px-10">
            UbuntuNet Managed IdP v{{ app_version() }}
        </div>
    </main>
</div>

{% block scripts %}{% endblock %}
</body>
</html>
