<form method="post" class="space-y-6 rounded-xl border border-gray-200 bg-white p-6">
    <input type="hidden" name="_token" value="{{ csrf_token(csrf_token_id) }}">

    <div class="grid gap-5 md:grid-cols-2">
        <div>
            <label for="username" class="mb-1.5 block text-sm font-medium text-gray-700">Username</label>
            <input id="username" name="user[username]" type="text" required value="{{ formData.username }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
        <div>
            <label for="password" class="mb-1.5 block text-sm font-medium text-gray-700">
                {{ require_password ? 'Password' : 'New Password' }}
            </label>
            <input id="password" name="user[password]" type="password" {{ require_password ? 'required minlength="12"' : 'minlength="12"' }}
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
            <p class="mt-1 text-xs text-gray-500">
                {{ require_password ? 'Minimum 12 characters. Saving this password also generates the NT hash needed for eduroam PEAP / MSCHAPv2.' : 'Leave blank to keep the current password. Updating it also refreshes the NT hash used by FreeRADIUS.' }}
            </p>
        </div>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
        <div>
            <label for="email" class="mb-1.5 block text-sm font-medium text-gray-700">Email</label>
            <input id="email" name="user[email]" type="email" value="{{ formData.email }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
            <p class="mt-1 text-xs text-gray-500">Required if you want the user to receive invite and password reset emails.</p>
        </div>
        <div>
            <label for="displayName" class="mb-1.5 block text-sm font-medium text-gray-700">Display Name</label>
            <input id="displayName" name="user[displayName]" type="text" value="{{ formData.displayName }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
        <div>
            <label for="givenName" class="mb-1.5 block text-sm font-medium text-gray-700">Given Name</label>
            <input id="givenName" name="user[givenName]" type="text" value="{{ formData.givenName }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
        <div>
            <label for="sn" class="mb-1.5 block text-sm font-medium text-gray-700">Surname</label>
            <input id="sn" name="user[sn]" type="text" value="{{ formData.sn }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
        <div>
            <label for="eppn" class="mb-1.5 block text-sm font-medium text-gray-700">eduPersonPrincipalName</label>
            <input id="eppn" name="user[eduPersonPrincipalName]" type="text" value="{{ formData.eduPersonPrincipalName }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
        <div>
            <label for="homeOrg" class="mb-1.5 block text-sm font-medium text-gray-700">schacHomeOrganization</label>
            <input id="homeOrg" name="user[schacHomeOrganization]" type="text" value="{{ formData.schacHomeOrganization }}"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
    </div>

    <div>
        <label for="affiliation" class="mb-1.5 block text-sm font-medium text-gray-700">eduPersonAffiliation</label>
        <input id="affiliation" name="user[eduPersonAffiliation]" type="text" value="{{ formData.eduPersonAffiliation }}"
               placeholder="member, staff, student"
               class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        <p class="mt-1 text-xs text-gray-500">Comma-separated values are stored as multi-value SAML attributes.</p>
    </div>

    <div>
        <label for="attributesJson" class="mb-1.5 block text-sm font-medium text-gray-700">Attributes JSON</label>
        <textarea id="attributesJson" name="user[attributesJson]" rows="10"
                  class="w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-xs outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">{{ formData.attributesJson }}</textarea>
        <p class="mt-1 text-xs text-gray-500">Optional overrides or extra SAML attributes. Values can be strings or arrays.</p>
    </div>

    <label class="flex items-center gap-2 text-sm text-gray-700">
        <input type="checkbox" name="user[isActive]" value="1" {{ formData.isActive ? 'checked' : '' }}
               class="rounded border-gray-300 text-idp-500 focus:ring-idp-500">
        Account active
    </label>

    <div class="flex items-center gap-3">
        <button type="submit"
                class="rounded-lg bg-idp-500 px-6 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-idp-600">
            {{ submit_label }}
        </button>
        <a href="{{ path('admin_tenant_user_index', {tenant: tenant.id}) }}" class="text-sm text-gray-600 hover:text-gray-800">Back</a>
    </div>
</form>
