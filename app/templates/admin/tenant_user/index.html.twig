{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ tenant.name }} Local Users{% endblock %}

{% block breadcrumb %}
<nav class="text-sm text-gray-500 mt-1">
    <a href="{{ path('admin_tenant_index') }}" class="hover:text-gray-700">Tenants</a>
    <span class="mx-2">/</span>
    <a href="{{ path('admin_tenant_show', {id: tenant.id}) }}" class="hover:text-gray-700">{{ tenant.name }}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-900">Local Users</span>
</nav>
{% endblock %}

{% block top_actions %}
<a href="{{ path('admin_tenant_show', {id: tenant.id}) }}"
   class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">
    Back to Tenant
</a>
<a href="{{ path('admin_tenant_user_new', {tenant: tenant.id}) }}"
   class="inline-flex items-center gap-2 px-4 py-2 bg-idp-500 hover:bg-idp-600 text-white rounded-lg text-sm font-medium">
    New User
</a>
<a href="{{ path('admin_tenant_registration_request_index', {tenant: tenant.id}) }}"
   class="inline-flex items-center gap-2 rounded-lg border border-blue-200 bg-blue-50 px-4 py-2 text-sm font-medium text-blue-700 hover:bg-blue-100">
    Registration Requests
</a>
{% endblock %}

{% block content %}
<div class="space-y-6">
    {% if not mailer_enabled %}
    <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
        <h2 class="text-sm font-semibold text-amber-900">Email Delivery Disabled</h2>
        <p class="mt-1 text-sm text-amber-800">
            Invitation and password reset emails will not be sent until <code>MAILER_DSN</code>, <code>MAILER_FROM_ADDRESS</code>, and <code>MAILER_FROM_NAME</code> are configured on the server.
        </p>
    </div>
    {% else %}
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-5">
        <h2 class="text-sm font-semibold text-slate-900">Invitation and Reset Delivery</h2>
        <p class="mt-1 text-sm text-slate-600">
            If SMTP delivery fails after you click <strong>Send Invite</strong> or <strong>Send Reset</strong>, the platform now shows a one-time fallback link you can copy and deliver manually.
        </p>
    </div>
    {% endif %}

    <div class="rounded-xl border border-blue-200 bg-blue-50 p-5">
        <h2 class="text-sm font-semibold text-blue-900">Bulk Import Users</h2>
        <p class="mt-1 text-sm text-blue-800">
            Accepted columns: <code>username,password,email,display_name,given_name,surname,eppn,affiliation,home_organization,active,attributes_json</code>.
        </p>
        <p class="mt-2 text-sm text-blue-800">
            Passwords entered here also generate the NT hash used by FreeRADIUS for PEAP / MSCHAPv2 when this tenant is used for eduroam.
        </p>
        <form method="post" enctype="multipart/form-data" action="{{ path('admin_tenant_user_bulk_import', {tenant: tenant.id}) }}" class="mt-4 grid gap-4 lg:grid-cols-2">
            <input type="hidden" name="_token" value="{{ csrf_token('tenant_user_bulk_' ~ tenant.id) }}">
            <div>
                <label class="mb-1.5 block text-sm font-medium text-gray-700">CSV File</label>
                <input type="file" name="csv_file" accept=".csv,text/csv"
                       class="block w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-700">
            </div>
            <div>
                <label class="mb-1.5 block text-sm font-medium text-gray-700">Or Paste CSV</label>
                <textarea name="csv_text" rows="6"
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 font-mono text-xs outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500"
                          placeholder="username,password,email,display_name,active&#10;jdoe,ChangeMe123!,jdoe@example.org,Jane Doe,1"></textarea>
            </div>
            <div class="lg:col-span-2 flex justify-end">
                <button type="submit"
                        class="rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-blue-700">
                    Import Users
                </button>
            </div>
        </form>
    </div>

    <form method="get" class="flex items-center gap-3">
        <div class="relative flex-1 max-w-sm">
            <input type="text" name="q" value="{{ q }}" placeholder="Search by username…"
                   class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-transparent focus:ring-2 focus:ring-idp-500">
        </div>
        <button type="submit" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-gray-50">Filter</button>
    </form>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        {% if pagination.totalItemCount == 0 %}
        <div class="px-6 py-12 text-center text-gray-400 text-sm">No local users found for this tenant.</div>
        {% else %}
        <table class="w-full text-sm">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Username</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Display</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Email</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                    <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Last login</th>
                    <th class="px-5 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
                {% for idpUser in pagination %}
                <tr class="hover:bg-gray-50">
                    <td class="px-5 py-3.5 font-medium text-gray-900">{{ idpUser.username }}</td>
                    <td class="px-5 py-3.5 text-gray-700">{{ idpUser.displayName ?? '—' }}</td>
                    <td class="px-5 py-3.5 text-gray-500">{{ idpUser.email ?? '—' }}</td>
                    <td class="px-5 py-3.5">
                        {% if idpUser.active %}
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Active
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">
                                <span class="w-1.5 h-1.5 rounded-full bg-gray-400"></span>Inactive
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-5 py-3.5 text-xs text-gray-400">{{ idpUser.lastLoginAt ? idpUser.lastLoginAt|date('Y-m-d H:i') : 'Never' }}</td>
                    <td class="px-5 py-3.5 text-right">
                        <div class="flex items-center justify-end gap-3">
                            <a href="{{ path('admin_tenant_user_edit', {tenant: tenant.id, user: idpUser.id}) }}"
                               class="text-xs text-idp-600 hover:underline">Edit</a>
                            {% if idpUser.email %}
                            <form method="post" action="{{ path('admin_tenant_user_send_invite', {tenant: tenant.id, user: idpUser.id}) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('tenant_user_send_invite_' ~ idpUser.id) }}">
                                <button type="submit" class="text-xs text-blue-600 hover:text-blue-800">Send Invite</button>
                            </form>
                            <form method="post" action="{{ path('admin_tenant_user_send_reset', {tenant: tenant.id, user: idpUser.id}) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('tenant_user_send_reset_' ~ idpUser.id) }}">
                                <button type="submit" class="text-xs text-indigo-600 hover:text-indigo-800">Send Reset</button>
                            </form>
                            {% endif %}
                            <form method="post" action="{{ path('admin_tenant_user_toggle_active', {tenant: tenant.id, user: idpUser.id}) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('tenant_user_toggle_' ~ idpUser.id) }}">
                                <button type="submit"
                                        class="text-xs {{ idpUser.active ? 'text-red-500 hover:text-red-700' : 'text-green-600 hover:text-green-800' }}">
                                    {{ idpUser.active ? 'Deactivate' : 'Activate' }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_tenant_user_delete', {tenant: tenant.id, user: idpUser.id}) }}" class="inline"
                                  onsubmit="return confirm('Delete local user {{ idpUser.username }}?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('tenant_user_delete_' ~ idpUser.id) }}">
                                <button type="submit" class="text-xs text-red-500 hover:text-red-700">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endblock %}
