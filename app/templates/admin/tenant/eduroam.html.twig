{% extends 'admin/base.html.twig' %}

{% block page_title %}eduroam Kit{% endblock %}

{% block breadcrumb %}
<nav class="text-sm text-gray-500 mt-1">
    <a href="{{ path('admin_tenant_index') }}" class="hover:text-gray-700">Tenants</a>
    <span class="mx-2">/</span>
    <a href="{{ path('admin_tenant_show', {id: tenant.id}) }}" class="hover:text-gray-700">{{ tenant.name }}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-900">eduroam</span>
</nav>
{% endblock %}

{% block top_actions %}
<a href="{{ path('admin_tenant_show', {id: tenant.id}) }}"
   class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">
    Back to Tenant
</a>
{% endblock %}

{% block content %}
<div class="space-y-6">
    {% if not bundle.enabled %}
    <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
        <h2 class="text-sm font-semibold text-amber-900">eduroam Kit Disabled</h2>
        <p class="mt-2 text-sm text-amber-800">Enable eduroam / FreeRADIUS onboarding in the tenant settings before using this page.</p>
        <a href="{{ path('admin_tenant_edit', {id: tenant.id}) }}" class="mt-4 inline-flex rounded-lg bg-white px-4 py-2 text-sm font-semibold text-amber-800 ring-1 ring-amber-200 hover:bg-amber-100">Open Tenant Settings</a>
    </div>
    {% else %}
    <div class="grid gap-4 md:grid-cols-4">
        <div class="rounded-xl border border-gray-200 bg-white p-5">
            <div class="text-xs font-medium uppercase tracking-wide text-gray-400">Realm</div>
            <div class="mt-2 text-sm font-semibold text-gray-900">{{ bundle.realm }}</div>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-5">
            <div class="text-xs font-medium uppercase tracking-wide text-gray-400">Backend</div>
            <div class="mt-2 text-sm font-semibold text-gray-900">{{ bundle.backendModeLabel }}</div>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-5">
            <div class="text-xs font-medium uppercase tracking-wide text-gray-400">EAP</div>
            <div class="mt-2 text-sm font-semibold text-gray-900">{{ bundle.defaultEapMethod|upper }}</div>
        </div>
        <div class="rounded-xl border border-gray-200 bg-white p-5">
            <div class="text-xs font-medium uppercase tracking-wide text-gray-400">Support</div>
            <div class="mt-2 text-sm font-semibold {{ bundle.supported ? 'text-green-700' : 'text-amber-700' }}">
                {{ bundle.supported ? 'Ready to wire' : 'Needs backend change' }}
            </div>
        </div>
    </div>

    {% if bundle.warnings is not empty %}
    <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
        <h2 class="text-sm font-semibold text-amber-900">Operator Notes</h2>
        <ul class="mt-3 space-y-2 text-sm text-amber-800">
            {% for warning in bundle.warnings %}
            <li>{{ warning }}</li>
            {% endfor %}
        </ul>
    </div>
    {% endif %}

    <div class="rounded-xl border border-gray-200 bg-white p-6">
        <h2 class="text-sm font-semibold text-gray-900">Generated FreeRADIUS Authentication Files</h2>
        <p class="mt-1 text-sm text-gray-500">This page only covers authentication-side snippets owned by the tenant backend. Client definitions and roaming proxy policy should come from switchboard.eduroam.africa or the national operator.</p>
    </div>

    {% for key, file in bundle.files %}
    <section class="rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex items-center justify-between gap-4">
            <div>
                <h3 class="text-sm font-semibold text-gray-900">{{ file.label }}</h3>
                <p class="mt-1 text-xs text-gray-500">{{ file.filename }}</p>
            </div>
            <div class="flex items-center gap-2">
                <button type="button"
                        onclick="navigator.clipboard.writeText(document.getElementById('eduroam-{{ key }}').innerText)"
                        class="rounded-lg border border-gray-300 px-3 py-2 text-xs font-medium text-gray-700 hover:bg-gray-50">
                    Copy
                </button>
                <a href="{{ path('admin_tenant_eduroam_file', {id: tenant.id, fileKey: key}) }}"
                   class="rounded-lg bg-idp-500 px-3 py-2 text-xs font-medium text-white hover:bg-idp-600">
                    Download
                </a>
            </div>
        </div>
        <pre id="eduroam-{{ key }}" class="mt-4 overflow-x-auto rounded-xl bg-slate-950 p-4 text-xs leading-5 text-slate-100">{{ file.content }}</pre>
    </section>
    {% endfor %}
    {% endif %}
</div>
{% endblock %}
