{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ tenant.name }}{% endblock %}

{% block breadcrumb %}
<nav class="mt-1 text-sm text-gray-500">
    <a href="{{ path('admin_tenant_index') }}" class="hover:text-gray-700">Tenants</a>
    <span class="mx-2">/</span>
    <span class="text-gray-900">{{ tenant.name }}</span>
</nav>
{% endblock %}

{% block top_actions %}
    {% if tenant.usesDatabaseAuth %}
    <a href="{{ path('admin_tenant_user_index', {tenant: tenant.id}) }}"
       class="inline-flex items-center gap-2 rounded-lg bg-idp-500 px-4 py-2 text-sm font-medium text-white hover:bg-idp-600">
        Local Users
    </a>
    {% endif %}
    <a href="{{ path('admin_tenant_edit', {id: tenant.id}) }}"
       class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50">
        Edit
    </a>
{% endblock %}

{% block content %}
<div class="max-w-4xl space-y-6">
    <section class="rounded-xl border border-gray-200 bg-white p-6">
        {% if tenant.logoUrl %}
        <img src="{{ tenant.logoUrl }}" alt="{{ tenant.name }} logo"
             class="mb-4 h-14 w-auto rounded-lg border border-gray-200 bg-white object-contain p-2">
        {% endif %}

        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="text-lg font-semibold text-gray-900">{{ tenant.name }}</h2>
                <p class="mt-1 text-sm text-gray-500">Slug: <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs">{{ tenant.slug }}</code></p>
            </div>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium
                {{ tenant.status == 'active' ? 'bg-green-100 text-green-800' : (tenant.status == 'pending' ? 'bg-amber-100 text-amber-800' : 'bg-red-100 text-red-800') }}">
                {{ tenant.status|capitalize }}
            </span>
        </div>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-6">
        <h3 class="text-sm font-semibold text-gray-900">Endpoints</h3>
        <dl class="mt-4 space-y-3">
            <div>
                <dt class="mb-1 text-xs text-gray-500">Metadata URL</dt>
                <dd><code class="text-xs text-gray-800">{{ tenant.metadataUrl }}</code></dd>
            </div>
            <div>
                <dt class="mb-1 text-xs text-gray-500">Entity ID</dt>
                <dd><code class="text-xs text-gray-800">{{ tenant.entityId }}</code></dd>
            </div>
            <div>
                <dt class="mb-1 text-xs text-gray-500">SSO Endpoint</dt>
                <dd><code class="text-xs text-gray-800">{{ tenant.ssoUrl }}</code></dd>
            </div>
            <div>
                <dt class="mb-1 text-xs text-gray-500">SLO Endpoint</dt>
                <dd><code class="text-xs text-gray-800">{{ tenant.sloUrl }}</code></dd>
            </div>
        </dl>
    </section>

    <!-- TENANT-SHOW-MARKER-A -->

    <section class="rounded-xl border border-gray-200 bg-white p-6">
        <h3 class="text-sm font-semibold text-gray-900">Configuration</h3>
        <dl class="mt-4 grid gap-4 sm:grid-cols-2">
            <div>
                <dt class="mb-1 text-xs text-gray-500">Auth Type</dt>
                <dd class="text-sm font-medium text-gray-900">{{ tenant.usesDatabaseAuth ? 'POSTGRESQL / MYSQL' : tenant.authType|upper }}</dd>
            </div>
            <div>
                <dt class="mb-1 text-xs text-gray-500">MFA Policy</dt>
                <dd class="text-sm font-medium capitalize text-gray-900">{{ tenant.mfaPolicy }}</dd>
            </div>
            <div>
                <dt class="mb-1 text-xs text-gray-500">Organisation</dt>
                <dd class="text-sm text-gray-700">{{ tenant.organizationName ?: '—' }}</dd>
            </div>
            <div>
                <dt class="mb-1 text-xs text-gray-500">Technical Contact</dt>
                <dd class="text-sm text-gray-700">{{ tenant.technicalContactEmail ?: '—' }}</dd>
            </div>
            {% if tenant.usesDatabaseAuth %}
            <div>
                <dt class="mb-1 text-xs text-gray-500">Local Users</dt>
                <dd class="text-sm font-medium text-gray-900">{{ localUserCount }}</dd>
            </div>
            {% endif %}
            <div>
                <dt class="mb-1 text-xs text-gray-500">eduroam</dt>
                <dd class="text-sm text-gray-700">{{ eduroam.enabled ? eduroam.backendModeLabel : 'Disabled' }}</dd>
            </div>
        </dl>
    </section>

    <section class="rounded-xl border border-gray-200 bg-white p-6">
        <h3 class="text-sm font-semibold text-gray-900">Metadata Aggregates</h3>
        {% if tenant.metadataAggregateUrls is empty %}
        <p class="mt-3 text-sm text-gray-500">None configured.</p>
        {% else %}
        <ul class="mt-3 space-y-2">
            {% for url in tenant.metadataAggregateUrls %}
            <li>
                <a href="{{ url }}" target="_blank" rel="noopener" class="truncate text-xs text-idp-600 hover:underline">{{ url }}</a>
            </li>
            {% endfor %}
        </ul>
        {% endif %}
    </section>

    {% if tenant.publishedFederations is not empty %}
    <section class="rounded-xl border border-gray-200 bg-white p-6">
        <h3 class="text-sm font-semibold text-gray-900">Published Federations</h3>
        <div class="mt-3 flex flex-wrap gap-2">
            {% for federation in tenant.publishedFederations %}
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-medium text-gray-700">{{ federation }}</span>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    <!-- TENANT-SHOW-MARKER-B -->

    <section class="rounded-xl border border-gray-200 bg-white p-6">
        <h3 class="text-sm font-semibold text-gray-900">Import Service Provider</h3>
        <p class="mt-1 text-sm text-gray-500">Add a service provider from a metadata URL or paste its XML metadata directly.</p>

        <form action="{{ path('admin_tenant_import_sp', {id: tenant.id}) }}" method="post" class="mt-4 space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('import-sp-' ~ tenant.id) }}">

            <div>
                <label for="metadata_url" class="mb-1 block text-xs text-gray-500">Metadata URL</label>
                <input id="metadata_url"
                       type="url"
                       name="metadata_url"
                       placeholder="https://sp.example.org/Shibboleth.sso/Metadata"
                       class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-idp-500 focus:outline-none focus:ring-2 focus:ring-idp-100">
            </div>

            <div>
                <label for="metadata_xml" class="mb-1 block text-xs text-gray-500">Metadata XML</label>
                <textarea id="metadata_xml"
                          name="metadata_xml"
                          rows="8"
                          placeholder="Paste SP EntityDescriptor XML here if you are not importing from a URL."
                          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm font-mono focus:border-idp-500 focus:outline-none focus:ring-2 focus:ring-idp-100"></textarea>
            </div>

            <label class="inline-flex items-center gap-2 text-sm text-gray-600">
                <input type="checkbox" name="approve" value="1" class="rounded border-gray-300 text-idp-600">
                Auto-approve this service provider
            </label>

            <div>
                <button type="submit"
                        class="inline-flex items-center gap-2 rounded-lg bg-idp-500 px-4 py-2 text-sm font-medium text-white hover:bg-idp-600">
                    Import SP
                </button>
            </div>
        </form>
    </section>
</div>
{% endblock %}
