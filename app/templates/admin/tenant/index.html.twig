{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ is_granted('ROLE_SUPER_ADMIN') ? 'Tenants' : 'My Tenants' }}{% endblock %}

{% block top_actions %}
    {% if is_granted('ROLE_SUPER_ADMIN') %}
    <a href="{{ path('admin_tenant_new') }}"
       class="inline-flex items-center gap-2 px-4 py-2 bg-idp-500 hover:bg-idp-600 text-white rounded-lg text-sm font-medium shadow-sm transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        New Tenant
    </a>
    {% endif %}
{% endblock %}

{% block content %}

{# ── Search + filter bar ─────────────────────────────────── #}
<form method="get" class="flex items-center gap-3 mb-6">
    <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input type="text" name="q" value="{{ search }}"
               placeholder="Search by name or slug…"
               class="w-full pl-9 pr-4 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
    </div>

    <select name="status"
            class="border border-gray-300 rounded-lg text-sm px-3 py-2 focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
        <option value="">All statuses</option>
        <option value="active"    {{ status == 'active'    ? 'selected' : '' }}>Active</option>
        <option value="pending"   {{ status == 'pending'   ? 'selected' : '' }}>Pending</option>
        <option value="suspended" {{ status == 'suspended' ? 'selected' : '' }}>Suspended</option>
    </select>

    <button type="submit"
            class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">
        Filter
    </button>

    {% if search or status %}
    <a href="{{ path('admin_tenant_index') }}" class="text-sm text-gray-500 hover:text-gray-700">Clear</a>
    {% endif %}
</form>

{# ── Tenant table ────────────────────────────────────────── #}
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    {% if pagination.totalItemCount == 0 %}
    <div class="px-6 py-16 text-center">
        <svg class="w-12 h-12 text-gray-200 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
        <p class="text-gray-400 text-sm font-medium">{{ is_granted('ROLE_SUPER_ADMIN') ? 'No tenants found.' : 'No tenants are assigned to your account.' }}</p>
        {% if is_granted('ROLE_SUPER_ADMIN') %}
        <a href="{{ path('admin_tenant_new') }}" class="mt-3 inline-block text-sm text-idp-600 hover:underline">
            Create your first tenant →
        </a>
        {% endif %}
    </div>
    {% else %}
    <table class="w-full text-sm">
        <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Institution</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Auth</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">SPs</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                <th class="px-5 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Created</th>
                <th class="px-5 py-3"></th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            {% for tenant in pagination %}
            <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-5 py-3.5">
                    <div class="flex items-center gap-3">
                        {% if tenant.logoUrl %}
                        <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center overflow-hidden rounded-xl border border-gray-200 bg-white p-1.5">
                            <img src="{{ tenant.logoUrl }}" alt="{{ tenant.name }} logo" class="h-full w-full object-contain">
                        </div>
                        {% else %}
                        <div class="w-10 h-10 rounded-xl bg-idp-50 text-idp-600 flex items-center justify-center font-bold text-sm flex-shrink-0">
                            {{ tenant.slug|first|upper }}
                        </div>
                        {% endif %}
                        <div>
                            <div class="font-medium text-gray-900">{{ tenant.name }}</div>
                            <div class="text-xs text-gray-400 font-mono">{{ tenant.slug }}.{{ app.request.host }}</div>
                            {% if tenant.publishedFederations is not empty %}
                            <div class="mt-1 flex flex-wrap gap-1.5">
                                {% for federation in tenant.publishedFederations|slice(0, 3) %}
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-[11px] font-medium text-gray-600">
                                    {{ federation }}
                                </span>
                                {% endfor %}
                                {% if tenant.publishedFederations|length > 3 %}
                                <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-[11px] font-medium text-gray-500">
                                    +{{ tenant.publishedFederations|length - 3 }}
                                </span>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td class="px-5 py-3.5">
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                        {{ tenant.authType == 'ldap'     ? 'bg-blue-100 text-blue-700' :
                           tenant.authType == 'saml'     ? 'bg-purple-100 text-purple-700' :
                           tenant.authType == 'radius'   ? 'bg-orange-100 text-orange-700' :
                                                           'bg-emerald-100 text-emerald-700' }}">
                        {{ tenant.usesDatabaseAuth ? 'POSTGRESQL / MYSQL' : tenant.authType|upper }}
                    </span>
                </td>
                <td class="px-5 py-3.5 text-gray-600">
                    {{ tenant.serviceProviders|length }}
                </td>
                <td class="px-5 py-3.5">
                    {% if tenant.status == 'active' %}
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>Active
                        </span>
                    {% elseif tenant.status == 'pending' %}
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                            <span class="w-1.5 h-1.5 rounded-full bg-amber-500 inline-block"></span>Pending
                        </span>
                    {% else %}
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                            <span class="w-1.5 h-1.5 rounded-full bg-red-500 inline-block"></span>Suspended
                        </span>
                    {% endif %}
                </td>
                <td class="px-5 py-3.5 text-gray-400 text-xs">
                    {{ tenant.createdAt|date('Y-m-d') }}
                </td>
                <td class="px-5 py-3.5 text-right">
                    <a href="{{ path('admin_tenant_show', {id: tenant.id}) }}"
                       class="text-idp-600 hover:text-idp-800 text-xs font-medium hover:underline">
                        Manage →
                    </a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# Pagination #}
    {% if pagination.pageCount > 1 %}
    <div class="px-5 py-3.5 border-t border-gray-100 flex items-center justify-between text-sm text-gray-500">
        <span>{{ pagination.totalItemCount }} {{ is_granted('ROLE_SUPER_ADMIN') ? 'total tenants' : 'assigned tenants' }}</span>
        <div class="flex items-center gap-1">
            {% if pagination.currentPageNumber > 1 %}
            <a href="{{ path('admin_tenant_index', {page: pagination.currentPageNumber - 1, q: search, status: status}) }}"
               class="px-3 py-1 border border-gray-300 rounded-md hover:bg-gray-50">← Prev</a>
            {% endif %}
            <span class="px-3 py-1 text-gray-700 font-medium">
                Page {{ pagination.currentPageNumber }} of {{ pagination.pageCount }}
            </span>
            {% if pagination.currentPageNumber < pagination.pageCount %}
            <a href="{{ path('admin_tenant_index', {page: pagination.currentPageNumber + 1, q: search, status: status}) }}"
               class="px-3 py-1 border border-gray-300 rounded-md hover:bg-gray-50">Next →</a>
            {% endif %}
        </div>
    </div>
    {% endif %}
    {% endif %}
</div>
{% endblock %}
