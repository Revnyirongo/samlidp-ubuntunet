{% extends 'admin/base.html.twig' %}

{% block page_title %}Edit SP: {{ sp.displayName }}{% endblock %}

{% block breadcrumb %}
<nav class="text-sm text-gray-500 mt-1">
    <a href="{{ path('admin_tenant_index') }}" class="hover:text-gray-700">Tenants</a>
    <span class="mx-2">/</span>
    <a href="{{ path('admin_tenant_show', {id: tenant.id}) }}" class="hover:text-gray-700">{{ tenant.name }}</a>
    <span class="mx-2">/</span>
    <a href="{{ path('admin_sp_show', {id: sp.id}) }}" class="hover:text-gray-700">{{ sp.displayName }}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-900">Edit</span>
</nav>
{% endblock %}

{% block content %}
<div class="max-w-2xl">
<form method="post" action="{{ path('admin_sp_edit', {id: sp.id}) }}">
    <input type="hidden" name="_token" value="{{ csrf_token('sp_edit_' ~ sp.id) }}">
    <input type="hidden" name="sp[attributeSelectionMode]" value="checkboxes">
    {% set requestedAttrs = sp.requestedAttributes ?? [] %}

    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-5 space-y-4">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">Service Provider Details</h2>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Display Name</label>
            <input type="text" name="sp[name]" value="{{ sp.name }}"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Entity ID</label>
            <input type="text" value="{{ sp.entityId }}" readonly
                   class="w-full px-3 py-2 border border-gray-200 bg-gray-50 rounded-lg text-sm font-mono text-gray-500">
            <p class="text-xs text-gray-400 mt-1">Entity ID cannot be changed after import.</p>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">ACS URL (HTTP-POST)</label>
            <input type="url" name="sp[acsUrl]" value="{{ sp.acsUrl }}"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">SLO URL (HTTP-Redirect)</label>
            <input type="url" name="sp[sloUrl]" value="{{ sp.sloUrl }}"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">NameID Format</label>
            <select name="sp[nameIdFormat]"
                    class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
                {% set formats = {
                    'urn:oasis:names:tc:SAML:2.0:nameid-format:persistent':  'Persistent (recommended)',
                    'urn:oasis:names:tc:SAML:2.0:nameid-format:transient':   'Transient',
                    'urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress': 'Email Address',
                    'urn:oasis:names:tc:SAML:2.0:nameid-format:unspecified': 'Unspecified',
                } %}
                {% for value, label in formats %}
                <option value="{{ value }}" {{ sp.nameIdFormat == value ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1.5">Technical Contact Email</label>
            <input type="email" name="sp[contactEmail]" value="{{ sp.contactEmail }}"
                   placeholder="it@sp-operator.org"
                   class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none">
        </div>

        <div class="flex gap-6 pt-2">
            <label class="flex items-center gap-2 text-sm text-gray-700">
                <input type="hidden" name="sp[signAssertions]" value="0">
                <input type="checkbox" name="sp[signAssertions]" value="1"
                       {{ sp.signAssertions ? 'checked' : '' }}
                       class="rounded border-gray-300 text-idp-500">
                Sign assertions
            </label>
            <label class="flex items-center gap-2 text-sm text-gray-700">
                <input type="hidden" name="sp[encryptAssertions]" value="0">
                <input type="checkbox" name="sp[encryptAssertions]" value="1"
                       {{ sp.encryptAssertions ? 'checked' : '' }}
                       class="rounded border-gray-300 text-idp-500">
                Encrypt assertions
            </label>
        </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-6 mb-5 space-y-5">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h2 class="text-sm font-semibold text-gray-900">Attribute Release</h2>
                <p class="mt-1 text-xs text-gray-500">
                    Review what this SP asked for and choose exactly what the IdP should release.
                </p>
            </div>
            {% if sp.attributeReleaseOverride %}
            <span class="inline-flex items-center rounded-full bg-amber-100 px-2.5 py-1 text-xs font-medium text-amber-800">
                SP-specific override
            </span>
            {% else %}
            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-600">
                Using tenant default
            </span>
            {% endif %}
        </div>

        <div class="grid gap-4 md:grid-cols-2">
            <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                <div class="flex items-center justify-between gap-3">
                    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-600">Requested By SP</h3>
                    <span class="text-xs text-gray-400">{{ requestedAttrs|length }} attributes</span>
                </div>
                {% if requestedAttrs is empty %}
                <p class="mt-3 text-xs text-gray-500">
                    No requested attributes were found in the SP metadata. You can still release a custom set below.
                </p>
                {% else %}
                <div class="mt-3 flex flex-wrap gap-2">
                    {% for attr in requestedAttrs %}
                    <span class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-medium text-gray-700 ring-1 ring-gray-200">
                        {{ attr }}
                    </span>
                    {% endfor %}
                </div>
                {% endif %}
            </div>

            <div class="rounded-xl border border-gray-200 bg-gray-50 p-4">
                <div class="flex items-center justify-between gap-3">
                    <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-600">Tenant Default</h3>
                    <span class="text-xs text-gray-400">{{ tenantDefaultRelease|length }} attributes</span>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                    {% for attr in tenantDefaultRelease %}
                    <span class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-medium text-gray-700 ring-1 ring-gray-200">
                        {{ attr }}
                    </span>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="rounded-xl border border-gray-200">
            <div class="border-b border-gray-200 px-4 py-3">
                <h3 class="text-sm font-medium text-gray-900">Release Selection</h3>
                <p class="mt-1 text-xs text-gray-500">
                    Checked attributes will be released to this SP. Matching the tenant default clears the override automatically.
                </p>
            </div>
            <div class="grid gap-3 p-4 md:grid-cols-2">
                {% for attr in attributeChoices %}
                <label class="flex items-start gap-3 rounded-lg border px-3 py-3 transition
                              {{ attr in requestedAttrs ? 'border-idp-200 bg-idp-50/40' : 'border-gray-200 bg-white' }}">
                    <input type="checkbox" name="sp[selectedAttributes][]" value="{{ attr }}"
                           {{ attr in effectiveRelease ? 'checked' : '' }}
                           class="mt-0.5 rounded border-gray-300 text-idp-600 focus:ring-idp-500">
                    <span class="min-w-0">
                        <span class="block text-sm font-medium text-gray-800 break-all">{{ attr }}</span>
                        {% if attr in requestedAttrs %}
                        <span class="mt-1 inline-flex items-center rounded-full bg-idp-100 px-2 py-0.5 text-[11px] font-medium text-idp-700">
                            Requested by metadata
                        </span>
                        {% endif %}
                    </span>
                </label>
                {% endfor %}
            </div>
        </div>

        <details class="rounded-xl border border-dashed border-gray-300 bg-gray-50">
            <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-gray-700">
                Advanced: custom attribute list
            </summary>
            <div class="border-t border-dashed border-gray-300 px-4 py-4">
                <p class="mb-3 text-xs text-gray-500">
                    Use this only when you need attributes outside the checkbox list. One SSP attribute name per line.
                </p>
                <textarea name="sp[attributeReleaseOverride]" rows="8"
                          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono focus:ring-2 focus:ring-idp-500 focus:border-transparent outline-none"
                          placeholder="uid&#10;mail&#10;cn&#10;eduPersonPrincipalName&#10;eduPersonAffiliation">{{ sp.attributeReleaseOverride ? sp.attributeReleaseOverride|join('\n') : '' }}</textarea>
            </div>
        </details>
    </div>

    <div class="flex items-center gap-3">
        <button type="submit"
                class="px-6 py-2.5 bg-idp-500 hover:bg-idp-600 text-white font-medium rounded-lg text-sm shadow-sm">
            Save Changes
        </button>
        <a href="{{ path('admin_sp_show', {id: sp.id}) }}"
           class="px-4 py-2.5 text-sm text-gray-600 hover:text-gray-800">Cancel</a>
    </div>
</form>
</div>
{% endblock %}
