{% extends 'admin/base.html.twig' %}

{% block page_title %}{{ sp.displayName }}{% endblock %}

{% block breadcrumb %}
<nav class="text-sm text-gray-500 mt-1">
    <a href="{{ path('admin_tenant_index') }}" class="hover:text-gray-700">Tenants</a>
    <span class="mx-2">/</span>
    <a href="{{ path('admin_tenant_show', {id: tenant.id}) }}" class="hover:text-gray-700">{{ tenant.name }}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-900 truncate max-w-xs inline-block align-bottom">{{ sp.displayName }}</span>
</nav>
{% endblock %}

{% block top_actions %}
<a href="{{ path('admin_sp_edit', {id: sp.id}) }}"
   class="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">
    Edit SP
</a>
{% endblock %}

{% block content %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <div class="lg:col-span-2 space-y-5">

        {# Overview card #}
        <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-start justify-between mb-5">
                <div>
                    <div class="flex items-center gap-3 mb-1">
                        <h2 class="text-lg font-semibold text-gray-900">{{ sp.displayName }}</h2>
                        {% if sp.approved %}
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>Approved
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">
                                <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>Pending approval
                            </span>
                        {% endif %}

                        {% if sp.source == 'metadata' or sp.source == 'edugain' %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-700">
                                Federation
                            </span>
                        {% endif %}
                    </div>
                    <p class="text-xs text-gray-400">Tenant: {{ tenant.name }}</p>
                </div>

                {# Approve/Revoke actions #}
                <div class="flex gap-2">
                    {% if not sp.approved %}
                    <form action="{{ path('admin_sp_approve', {id: sp.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve-sp-' ~ sp.id) }}">
                        <button class="px-3 py-1.5 bg-green-600 hover:bg-green-700 text-white text-xs font-medium rounded-lg">
                            ✓ Approve
                        </button>
                    </form>
                    {% else %}
                    <form action="{{ path('admin_sp_revoke', {id: sp.id}) }}" method="post">
                        <input type="hidden" name="_token" value="{{ csrf_token('revoke-sp-' ~ sp.id) }}">
                        <button class="px-3 py-1.5 bg-amber-500 hover:bg-amber-600 text-white text-xs font-medium rounded-lg">
                            Revoke
                        </button>
                    </form>
                    {% endif %}
                </div>
            </div>

            {# Details grid #}
            <dl class="space-y-3">
                {% set fields = [
                    {label: 'Entity ID',        value: sp.entityId,     mono: true},
                    {label: 'ACS URL',          value: sp.acsUrl,       mono: true},
                    {label: 'SLO URL',          value: sp.sloUrl,       mono: true},
                    {label: 'NameID Format',    value: sp.nameIdFormat, mono: true},
                    {label: 'Contact',          value: sp.contactEmail, mono: false},
                    {label: 'Source',           value: sp.source,       mono: false},
                ] %}
                {% for field in fields %}
                {% if field.value %}
                <div class="flex items-start gap-3 py-2 border-b border-gray-50 last:border-0">
                    <dt class="text-xs text-gray-500 w-32 flex-shrink-0 pt-0.5">{{ field.label }}</dt>
                    <dd class="text-sm {{ field.mono ? 'font-mono text-xs' : '' }} text-gray-800 flex-1 break-all">
                        {{ field.value }}
                    </dd>
                    {% if field.mono %}
                    <button onclick="navigator.clipboard.writeText('{{ field.value }}')"
                            class="text-gray-300 hover:text-gray-500 flex-shrink-0" title="Copy">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                        </svg>
                    </button>
                    {% endif %}
                </div>
                {% endif %}
                {% endfor %}
            </dl>
        </div>

        {# Certificate block #}
        {% if sp.certificate %}
        <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-gray-900">SP Signing Certificate</h3>
                {% if sp.certificateExpiresAt %}
                    {% if sp.certificateExpiresAt < date() %}
                        <span class="text-xs px-2.5 py-1 bg-red-100 text-red-700 rounded-full font-medium">
                            ✗ Expired {{ sp.certificateExpiresAt|date('Y-m-d') }}
                        </span>
                    {% elseif sp.certificateExpiresAt < date('+30 days') %}
                        <span class="text-xs px-2.5 py-1 bg-amber-100 text-amber-700 rounded-full font-medium">
                            ⚠ Expires {{ sp.certificateExpiresAt|date('Y-m-d') }}
                        </span>
                    {% else %}
                        <span class="text-xs px-2.5 py-1 bg-green-100 text-green-700 rounded-full font-medium">
                            ✓ Valid until {{ sp.certificateExpiresAt|date('Y-m-d') }}
                        </span>
                    {% endif %}
                {% endif %}
            </div>
            <pre class="text-xs font-mono bg-gray-50 border border-gray-200 rounded-lg p-3 overflow-auto max-h-32 text-gray-600 whitespace-pre-wrap break-all">{{ sp.certificate }}</pre>
        </div>
        {% endif %}

        {# Raw metadata XML #}
        {% if sp.rawMetadataXml %}
        <div class="bg-white rounded-xl border border-gray-200 p-6">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-gray-900">Raw Metadata XML</h3>
                <a href="{{ path('admin_sp_metadata_xml', {id: sp.id}) }}"
                   class="text-xs text-idp-600 hover:underline">Download XML</a>
            </div>
            <pre class="text-xs font-mono bg-gray-50 border border-gray-200 rounded-lg p-3 overflow-auto max-h-48 text-gray-600">{{ sp.rawMetadataXml|escape }}</pre>
        </div>
        {% endif %}
    </div>

    {# Right sidebar #}
    <div class="space-y-5">

        {# Metadata refresh timestamps #}
        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Timestamps</h3>
            <dl class="space-y-2 text-xs">
                <div class="flex justify-between">
                    <dt class="text-gray-500">Imported</dt>
                    <dd class="text-gray-700">{{ sp.createdAt|date('Y-m-d H:i') }}</dd>
                </div>
                <div class="flex justify-between">
                    <dt class="text-gray-500">Last updated</dt>
                    <dd class="text-gray-700">{{ sp.updatedAt|date('Y-m-d H:i') }}</dd>
                </div>
                {% if sp.metadataRefreshedAt %}
                <div class="flex justify-between">
                    <dt class="text-gray-500">Metadata refreshed</dt>
                    <dd class="text-gray-700">{{ sp.metadataRefreshedAt|date('Y-m-d H:i') }}</dd>
                </div>
                {% endif %}
            </dl>
        </div>

        {# Attribute release #}
        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Attribute Release</h3>
            {% if effectiveRelease is empty %}
                <p class="text-xs text-gray-400">No attributes selected for release.</p>
            {% else %}
                <ul class="space-y-1">
                    {% for attr in effectiveRelease %}
                    <li class="text-xs font-mono text-gray-600 bg-gray-50 px-2 py-1 rounded">
                        {{ attr }}
                        {% if attr in (sp.requestedAttributes ?? []) %}
                        <span class="ml-1 text-[10px] font-sans uppercase tracking-wide text-idp-600">requested</span>
                        {% endif %}
                    </li>
                    {% endfor %}
                </ul>
                {% if sp.attributeReleaseOverride %}
                <p class="text-xs text-amber-600 mt-2">⚑ SP-specific override active</p>
                {% else %}
                <p class="text-xs text-gray-400 mt-2">Inherited from tenant default policy.</p>
                {% endif %}
            {% endif %}
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Requested Attributes</h3>
            {% if sp.requestedAttributes is empty %}
            <p class="text-xs text-gray-400">No requested attributes were found in the imported metadata.</p>
            {% else %}
            <ul class="space-y-1">
                {% for attr in sp.requestedAttributes %}
                <li class="text-xs font-mono text-gray-600 bg-gray-50 px-2 py-1 rounded">{{ attr }}</li>
                {% endfor %}
            </ul>
            {% endif %}
        </div>

        <div class="bg-white rounded-xl border border-gray-200 p-5">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">Tenant Default Release</h3>
            <ul class="space-y-1">
                {% for attr in tenantDefaultRelease %}
                <li class="text-xs font-mono text-gray-600 bg-gray-50 px-2 py-1 rounded">{{ attr }}</li>
                {% endfor %}
            </ul>
        </div>

        {# Danger zone #}
        <div class="bg-white rounded-xl border border-red-200 p-5">
            <h3 class="text-sm font-semibold text-red-700 mb-3">Remove SP</h3>
            <form action="{{ path('admin_sp_delete', {id: sp.id}) }}" method="post"
                  onsubmit="return confirm('Delete SP \'{{ sp.displayName }}\' permanently?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete-sp-' ~ sp.id) }}">
                <button type="submit"
                        class="w-full px-3 py-2 bg-red-600 hover:bg-red-700 text-white text-xs font-medium rounded-lg">
                    Delete SP
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
