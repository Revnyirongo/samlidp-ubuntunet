{% extends 'security/_auth_layout.html.twig' %}

{% block auth_title %}{{ mode == 'set' ? 'Set your ' ~ tenant.name ~ ' password' : 'Choose a new ' ~ tenant.name ~ ' password' }}{% endblock %}
{% block auth_subtitle %}Use a strong password with at least 12 characters.{% endblock %}

{% block auth_content %}
<form method="post" class="space-y-5">
    <input type="hidden" name="_token" value="{{ csrf_token('tenant_reset_password') }}">
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
        Tenant: <span class="font-semibold text-slate-900">{{ tenant.name }}</span>
    </div>
    <div>
        <label for="password" class="mb-1.5 block text-sm font-semibold text-slate-700">New password</label>
        <input id="password" name="password" type="password" minlength="12" required
               class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500">
    </div>
    <div>
        <label for="password_confirm" class="mb-1.5 block text-sm font-semibold text-slate-700">Confirm password</label>
        <input id="password_confirm" name="password_confirm" type="password" minlength="12" required
               class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500">
    </div>
    <button type="submit"
            class="w-full rounded-2xl bg-idp-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-idp-500">
        Save password
    </button>
    <p class="text-center text-sm text-slate-500">After saving, you will be shown the next step.</p>
</form>
{% endblock %}
