{% extends 'admin/base.html.twig' %}
{% block page_title %}Two-Factor Sign-In{% endblock %}

{% block content %}
<div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-bold text-slate-900">
            {{ user.totpEnabled ? 'Authenticator app is enabled' : 'Set up an authenticator app' }}
        </h2>
        <p class="mt-2 text-sm text-slate-600">
            Use a TOTP-compatible authenticator app such as Google Authenticator, Microsoft Authenticator, FreeOTP, or Authy.
        </p>

        {% if user.totpEnabled %}
        <div class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm text-emerald-900">
            A verification code will be required after password sign-in.
        </div>

        <form method="post" action="{{ path('app_profile_mfa_disable') }}" class="mt-6 space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('admin_mfa_disable') }}">
            <div>
                <label for="disable_code" class="mb-1.5 block text-sm font-semibold text-slate-700">Current authenticator code</label>
                <input id="disable_code" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required
                       class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm tracking-[0.35em] text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500"
                       placeholder="123456">
            </div>
            <button type="submit"
                    class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-700 transition hover:bg-red-100">
                Disable two-factor sign-in
            </button>
        </form>
        {% else %}
        <div class="mt-5 space-y-4">
            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm text-slate-700">
                <p class="font-semibold text-slate-900">Scan QR code</p>
                <div class="mt-3 flex justify-center">
                    <div id="admin-mfa-qr" class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"></div>
                </div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
                <p class="font-semibold text-slate-900">Manual setup secret</p>
                <p class="mt-2 break-all font-mono text-base text-slate-900">{{ setup_secret }}</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
                <p class="font-semibold text-slate-900">Setup URI</p>
                <p class="mt-2 break-all font-mono text-xs text-slate-900">{{ setup_uri }}</p>
            </div>
        </div>

        <form method="post" class="mt-6 space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('admin_mfa_setup') }}">
            <div>
                <label for="code" class="mb-1.5 block text-sm font-semibold text-slate-700">Verification code</label>
                <input id="code" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required
                       class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm tracking-[0.35em] text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500"
                       placeholder="123456">
            </div>
            <button type="submit"
                    class="rounded-2xl bg-idp-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-idp-500">
                Enable two-factor sign-in
            </button>
        </form>
        {% endif %}
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h3 class="text-base font-bold text-slate-900">How it works</h3>
        <ol class="mt-4 space-y-3 text-sm text-slate-600">
            <li>1. Scan the QR code with your authenticator app. Use the manual secret only if you cannot scan.</li>
            <li>2. Enter the current six-digit code to confirm setup.</li>
            <li>3. Keep your phone time set automatically. Time drift will cause code validation to fail.</li>
            <li>4. Future sign-ins will ask for password first, then the authenticator code.</li>
        </ol>
    </div>
</div>
{% endblock %}

{% block scripts %}
{% if not user.totpEnabled and setup_uri %}
<script src="/assets/vendor/qrcode.min.js"></script>
<script>
    (function () {
        const target = document.getElementById('admin-mfa-qr');
        if (!target || typeof QRCode === 'undefined') {
            return;
        }

        new QRCode(target, {
            text: {{ setup_uri|json_encode|raw }},
            width: 184,
            height: 184,
            correctLevel: QRCode.CorrectLevel.M
        });
    })();
</script>
{% endif %}
{% endblock %}
