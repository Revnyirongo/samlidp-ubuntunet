<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex,nofollow">
    <title>{% block auth_title %}eduID.africa{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ubuntu: { 500: '#d96a2e', 600: '#bf5720' },
                        idp: { 50: '#eef4fb', 100: '#d8e7f6', 500: '#1f5f97', 600: '#174d7d', 700: '#103857' }
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Manrope', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(217, 106, 46, 0.11), transparent 20rem),
                radial-gradient(circle at bottom right, rgba(31, 95, 151, 0.14), transparent 24rem),
                linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        }
    </style>
</head>
<body class="min-h-full">
    <div class="mx-auto flex min-h-screen max-w-5xl items-center px-4 py-8 sm:px-6 lg:px-8">
        <div class="w-full overflow-hidden rounded-[2rem] border border-slate-200/70 bg-white/90 shadow-[0_30px_70px_rgba(15,23,42,0.08)] backdrop-blur lg:grid lg:grid-cols-[0.95fr_1.05fr]">
            <section class="hidden border-r border-slate-200/70 bg-slate-950 px-10 py-12 text-white lg:block">
                <div class="mb-10 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2">
                    <div class="flex h-9 w-9 items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-ubuntu-500 to-idp-600 text-sm font-extrabold text-white">
                        {% if auth_brand_logo is defined and auth_brand_logo %}
                            <img src="{{ auth_brand_logo }}" alt="{{ auth_brand_name|default('Tenant') }}" class="h-full w-full object-contain bg-white p-1.5">
                        {% else %}
                            <img src="/assets/default-security-shield.svg" alt="Security shield" class="h-full w-full object-contain bg-white p-1.5">
                        {% endif %}
                    </div>
                    <div>
                        <div class="text-sm font-extrabold tracking-tight">{{ auth_brand_name|default('eduID.africa') }}</div>
                        <div class="text-xs text-white/60">Account services</div>
                    </div>
                </div>
                <h1 class="max-w-md text-4xl font-extrabold tracking-tight">{{ block('auth_title') }}</h1>
                <p class="mt-4 max-w-md text-sm leading-6 text-white/70">{{ block('auth_subtitle') }}</p>
            </section>

            <section class="px-6 py-8 sm:px-10 sm:py-10">
                <div class="mx-auto max-w-md">
                    <div class="mb-8 lg:hidden">
                        <div class="mb-4 flex h-12 w-12 items-center justify-center overflow-hidden rounded-2xl bg-gradient-to-br from-ubuntu-500 to-idp-600 text-base font-extrabold text-white shadow-sm">
                            {% if auth_brand_logo is defined and auth_brand_logo %}
                                <img src="{{ auth_brand_logo }}" alt="{{ auth_brand_name|default('Tenant') }}" class="h-full w-full object-contain bg-white p-1.5">
                            {% else %}
                                <img src="/assets/default-security-shield.svg" alt="Security shield" class="h-full w-full object-contain bg-white p-1.5">
                            {% endif %}
                        </div>
                        <h1 class="text-3xl font-extrabold tracking-tight text-slate-900">{{ block('auth_title') }}</h1>
                        <p class="mt-2 text-sm text-slate-500">{{ block('auth_subtitle') }}</p>
                    </div>

                    {% if mailer_enabled is defined and not mailer_enabled %}
                    <div class="mb-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                        Email delivery is not configured on this server yet. Set <code>MAILER_DSN</code>, <code>MAILER_FROM_ADDRESS</code>, and <code>MAILER_FROM_NAME</code> in <code>.env</code> before relying on reset or registration emails.
                    </div>
                    {% endif %}

                    {% for type, messages in app.flashes %}
                        {% set colorMap = {'success': 'blue', 'danger': 'red', 'warning': 'amber', 'info': 'blue'} %}
                        {% set color = colorMap[type] ?? 'gray' %}
                        {% for message in messages %}
                        <div class="mb-4 rounded-2xl border border-{{ color }}-200 bg-{{ color }}-50 px-4 py-3 text-sm text-{{ color }}-800">
                            {{ message }}
                        </div>
                        {% endfor %}
                    {% endfor %}

                    {% block auth_content %}{% endblock %}

                    <div class="mt-6 text-xs text-slate-400">
                        eduID.africa v{{ app_version() }}
                    </div>
                </div>
            </section>
        </div>
    </div>
</body>
</html>
