<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex,nofollow">
    <title>Verify sign-in - eduID.africa</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Manrope', sans-serif; }</style>
</head>
<body class="min-h-screen bg-[radial-gradient(circle_at_top_left,rgba(217,106,46,0.12),transparent_18rem),radial-gradient(circle_at_bottom_right,rgba(31,95,151,0.16),transparent_24rem),linear-gradient(180deg,#f8fafc_0%,#eef2f7_100%)]">
    <div class="mx-auto flex min-h-screen max-w-6xl items-center justify-center px-4 py-8">
        <div class="w-full max-w-md rounded-[2rem] border border-slate-200/70 bg-white/90 p-8 shadow-[0_30px_70px_rgba(15,23,42,0.08)] backdrop-blur">
            <div class="mb-8 text-center">
                <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-700 text-white shadow-sm">
                    <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11c0 1.105-.672 2-1.5 2S9 12.105 9 11s.672-2 1.5-2 1.5.895 1.5 2zm0 0V8m-6 8h12a2 2 0 002-2V9a2 2 0 00-2-2h-1V6a5 5 0 00-10 0v1H6a2 2 0 00-2 2v5a2 2 0 002 2z"/>
                    </svg>
                </div>
                <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">Verify your sign-in</h1>
                <p class="mt-2 text-sm text-slate-500">Enter the current six-digit code from your authenticator app for {{ user.email }}.</p>
            </div>

            {% for type, messages in app.flashes %}
                {% set colorMap = {'success': 'green', 'danger': 'red', 'warning': 'amber', 'info': 'blue'} %}
                {% set color = colorMap[type] ?? 'gray' %}
                {% for message in messages %}
                <div class="mb-4 rounded-2xl border border-{{ color }}-200 bg-{{ color }}-50 px-4 py-3 text-sm text-{{ color }}-800">
                    {{ message }}
                </div>
                {% endfor %}
            {% endfor %}

            <form method="post" class="space-y-5">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_2fa_challenge') }}">
                <div>
                    <label for="code" class="mb-1.5 block text-sm font-semibold text-slate-700">Authenticator code</label>
                    <input id="code" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus
                           class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-center text-xl tracking-[0.35em] text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-blue-600"
                           placeholder="123456">
                </div>
                <button type="submit"
                        class="w-full rounded-2xl bg-blue-700 px-4 py-3 text-sm font-bold text-white transition hover:bg-blue-600">
                    Continue
                </button>
            </form>
        </div>
    </div>
</body>
</html>
