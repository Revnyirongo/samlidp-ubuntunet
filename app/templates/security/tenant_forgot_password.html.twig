{% extends 'security/_auth_layout.html.twig' %}

{% block auth_title %}Reset your {{ tenant.name }} password{% endblock %}
{% block auth_subtitle %}Enter the email address stored on your institutional account and we will send you a secure reset link.{% endblock %}

{% block auth_content %}
{% if updated %}
<div class="space-y-4">
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-4 text-sm text-emerald-900">
        Your password has been updated.
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-600">
        <p class="font-semibold text-slate-900">Next step</p>
        <p class="mt-2">Go back to the service you want to access and start sign-in again.</p>
    </div>
    <div class="text-center text-sm text-slate-500">
        <a href="{{ path('app_tenant_continue_to_login', {slug: tenant.slug}) }}" class="font-semibold text-idp-600 hover:underline">Open {{ tenant.name }} sign-in</a>
    </div>
</div>
{% else %}
<form method="post" class="space-y-5">
    <input type="hidden" name="_token" value="{{ csrf_token('tenant_forgot_password_' ~ tenant.slug) }}">
    <input type="hidden" name="_challenge" value="{{ form_challenge }}">
    <div class="hidden" aria-hidden="true">
        <label for="company">Company</label>
        <input id="company" name="company" type="text" tabindex="-1" autocomplete="off">
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
        Tenant: <span class="font-semibold text-slate-900">{{ tenant.name }}</span>
    </div>
    <div>
        <label for="email" class="mb-1.5 block text-sm font-semibold text-slate-700">Email address</label>
        <input id="email" name="email" type="email" required
               class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500"
               placeholder="student@institution.ac.ke">
    </div>
    <button type="submit"
            class="w-full rounded-2xl bg-idp-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-idp-500">
        Send reset link
    </button>
    <p class="text-center text-sm text-slate-500">
        Return to the application you were signing into after you update your password.
    </p>
    <p class="text-center text-sm text-slate-500">
        <a href="{{ path('app_tenant_register', {slug: tenant.slug}) }}" class="font-semibold text-idp-600 hover:underline">Need an account? Request one here</a>
    </p>
    {% if tenant.mfaPolicy != 'none' %}
    <p class="text-center text-sm text-slate-500">
        <a href="{{ path('app_tenant_mfa_setup', {slug: tenant.slug}) }}" class="font-semibold text-idp-600 hover:underline">Set up an authenticator app</a>
    </p>
    {% endif %}
</form>
{% endif %}
{% endblock %}
