{% extends 'security/_auth_layout.html.twig' %}

{% block auth_title %}Set up sign-in verification for {{ tenant.name }}{% endblock %}
{% block auth_subtitle %}Use an authenticator app to protect your institutional account with a one-time code.{% endblock %}

{% block auth_content %}
{% if pending_setup %}
<div class="space-y-5">
    <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm text-slate-700">
        <p class="font-semibold text-slate-900">Scan QR code</p>
        <div class="mt-3 flex justify-center">
            <div id="tenant-mfa-qr" class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"></div>
        </div>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
        <p class="font-semibold text-slate-900">Manual setup secret</p>
        <p class="mt-2 break-all font-mono text-base text-slate-900">{{ pending_setup.secret }}</p>
    </div>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
        <p class="font-semibold text-slate-900">Setup URI</p>
        <p class="mt-2 break-all font-mono text-xs text-slate-900">{{ setup_uri }}</p>
    </div>

    <form method="post" class="space-y-4">
        <input type="hidden" name="stage" value="confirm">
        <input type="hidden" name="_token" value="{{ csrf_token('tenant_mfa_setup_confirm_' ~ tenant.slug) }}">
        <div>
            <label for="code" class="mb-1.5 block text-sm font-semibold text-slate-700">Verification code</label>
            <input id="code" name="code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autofocus
                   class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-center text-xl tracking-[0.35em] text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500"
                   placeholder="123456">
        </div>
        <button type="submit"
                class="w-full rounded-2xl bg-idp-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-idp-500">
            Confirm and enable
        </button>
    </form>
    <p class="text-sm text-slate-500">
        Keep your phone time set automatically. If scanning is not possible, use the manual secret above.
    </p>
</div>
{% else %}
<form method="post" class="space-y-5">
    <input type="hidden" name="stage" value="identify">
    <input type="hidden" name="_token" value="{{ csrf_token('tenant_mfa_setup_identify_' ~ tenant.slug) }}">
    <div>
        <label for="identifier" class="mb-1.5 block text-sm font-semibold text-slate-700">Username or email</label>
        <input id="identifier" name="identifier" type="text" required value="{{ formData.identifier }}"
               class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500">
    </div>
    <div>
        <label for="password" class="mb-1.5 block text-sm font-semibold text-slate-700">Current password</label>
        <input id="password" name="password" type="password" required
               class="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition focus:border-transparent focus:ring-2 focus:ring-idp-500">
    </div>
    <button type="submit"
            class="w-full rounded-2xl bg-idp-600 px-4 py-3 text-sm font-bold text-white transition hover:bg-idp-500">
        Continue
    </button>
    <p class="text-center text-sm text-slate-500">
        After setup, return to the service you want to access and start sign-in again.
    </p>
</form>
{% endif %}
{% endblock %}

{% block scripts %}
{% if pending_setup and setup_uri %}
<script src="/assets/vendor/qrcode.min.js"></script>
<script>
    (function () {
        const target = document.getElementById('tenant-mfa-qr');
        if (!target || typeof QRCode === 'undefined') {
            return;
        }

        new QRCode(target, {
            text: {{ setup_uri|json_encode|raw }},
            width: 184,
            height: 184,
            correctLevel: QRCode.CorrectLevel.M
        });
    })();
</script>
{% endif %}
{% endblock %}
