<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="robots" content="noindex,nofollow">
    <title>{{ status_code|default(500) }} {{ status_text|default('Error') }} | eduID.africa</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ubuntu: { 500: '#d96a2e', 600: '#bf5720' },
                        idp: { 500: '#1f5f97', 600: '#174d7d' }
                    }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Manrope', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(217, 106, 46, 0.11), transparent 20rem),
                radial-gradient(circle at bottom right, rgba(31, 95, 151, 0.14), transparent 24rem),
                linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        }
    </style>
</head>
<body class="min-h-screen">
    <main class="mx-auto flex min-h-screen max-w-4xl items-center px-4 py-10 sm:px-6 lg:px-8">
        <section class="w-full overflow-hidden rounded-[2rem] border border-slate-200/70 bg-white/92 shadow-[0_30px_70px_rgba(15,23,42,0.08)] backdrop-blur lg:grid lg:grid-cols-[0.9fr_1.1fr]">
            <div class="hidden border-r border-slate-200/70 bg-slate-950 px-10 py-12 text-white lg:block">
                <div class="mb-10 inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/5 px-4 py-2">
                    <div class="flex h-9 w-9 items-center justify-center rounded-2xl bg-gradient-to-br from-ubuntu-500 to-idp-600 text-sm font-extrabold text-white">U</div>
                    <div>
                        <div class="text-sm font-extrabold tracking-tight">eduID.africa</div>
                        <div class="text-xs text-white/60">Service status</div>
                    </div>
                </div>
                <div class="text-xs font-bold uppercase tracking-[0.2em] text-white/45">{% block error_label %}Request failed{% endblock %}</div>
                <h1 class="mt-4 max-w-sm text-5xl font-extrabold tracking-tight">{% block error_code %}{{ status_code|default(500) }}{% endblock %}</h1>
                <p class="mt-4 max-w-sm text-sm leading-6 text-white/70">{% block error_sidecopy %}{{ status_text|default('An unexpected error occurred.') }}{% endblock %}</p>
            </div>

            <div class="px-6 py-8 sm:px-10 sm:py-10">
                <div class="mx-auto max-w-md">
                    <div class="mb-6 lg:hidden">
                        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-ubuntu-500 to-idp-600 text-base font-extrabold text-white shadow-sm">U</div>
                        <div class="text-sm font-bold uppercase tracking-[0.16em] text-slate-400">eduID.africa</div>
                    </div>

                    <div class="text-sm font-bold uppercase tracking-[0.16em] text-slate-400">{% block error_kicker %}Request failed{% endblock %}</div>
                    <h1 class="mt-2 text-3xl font-extrabold tracking-tight text-slate-900">{% block error_title %}{{ status_code|default(500) }} {{ status_text|default('Error') }}{% endblock %}</h1>
                    <p class="mt-3 text-sm leading-6 text-slate-600">{% block error_copy %}The service could not complete this request. If the problem persists, retry once and then contact the service administrator.{% endblock %}</p>

                    <div class="mt-8 flex flex-wrap gap-3">
                        {% block error_actions %}
                            <a href="/login" class="rounded-2xl bg-idp-600 px-5 py-3 text-sm font-bold text-white transition hover:bg-idp-500">
                                Open Login
                            </a>
                            <a href="/" class="rounded-2xl border border-slate-300 px-5 py-3 text-sm font-bold text-slate-700 transition hover:bg-slate-50">
                                Return Home
                            </a>
                        {% endblock %}
                    </div>

                    <div class="mt-8 space-y-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-600">
                        <div>Error code: <span class="font-mono font-semibold text-slate-900">{{ status_code|default(500) }}</span></div>
                        <div>Request ID: <span class="font-mono font-semibold text-slate-900">{{ app.request.attributes.get('_request_id', 'UNAVAILABLE') }}</span></div>
                        <div>Path: <span class="font-mono text-slate-700">{{ app.request.requestUri|default('/') }}</span></div>
                        <div>Version: <span class="font-mono font-semibold text-slate-900">{{ app_version() }}</span></div>
                    </div>

                    <div class="mt-4 rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm text-slate-600">
                        {% block error_help %}
                        If you contact support, include the request ID above so the event can be found quickly in the logs.
                        {% endblock %}
                    </div>
                </div>
            </div>
        </section>
    </main>
</body>
</html>
