# ============================================================
# UbuntuNet SAML IdP — Environment Configuration
# Copy this to .env and fill in all values before deploying
# ============================================================

# ── Application ─────────────────────────────────────────────
APP_ENV=prod
APP_SECRET=CHANGE_ME_32_CHAR_RANDOM_STRING_HERE

# ── Domain ──────────────────────────────────────────────────
# Main hostname. Tenant IdPs will be served at <slug>.<SAMLIDP_HOSTNAME>
SAMLIDP_HOSTNAME=example.com
# Regex-escaped hostname for nginx and trusted-host matching.
SAMLIDP_HOSTNAME_REGEX=example\.com

# ── Database (PostgreSQL recommended) ────────────────────────
DB_NAME=samlidp
DB_USER=samlidp
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?serverVersion=16&charset=utf8

# Optional: legacy PostgreSQL database used for one-time imports into the new schema.
LEGACY_DATABASE_URL=

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ── Container DNS Resolvers ─────────────────────────────────
# Used by app, worker, scheduler, and SimpleSAMLphp for outbound
# metadata fetches and other external hostname resolution.
DNS_RESOLVER_PRIMARY=1.1.1.1
DNS_RESOLVER_SECONDARY=8.8.8.8

# ── Wildcard Certificate Vault Password ──────────────────────
# Used to decrypt the encrypted wildcard private key
VAULT_PASS=CHANGE_ME_VAULT_PASS

# ── SimpleSAMLphp ───────────────────────────────────────────
# Generate with: php -r "echo password_hash('yourpassword', PASSWORD_BCRYPT);"
SSP_ADMIN_PASSWORD_HASH=CHANGE_ME_BCRYPT_HASH
# Generate with: openssl rand -base64 32
SSP_SECRET_SALT=CHANGE_ME_LONG_RANDOM_SALT_STRING

# ── Mailer ──────────────────────────────────────────────────
# Examples:
#   smtp://user:pass@smtp.example.com:587
#   sendgrid+smtp://apikey:SENDGRID_KEY@default
MAILER_DSN=smtp://localhost:25
# Example for Microsoft 365:
# MAILER_DSN=smtp://USERNAME:PASSWORD@smtp.office365.com:587?encryption=tls&auth_mode=login
MAILER_FROM_ADDRESS=noreply@example.com
MAILER_FROM_NAME="Managed Identity Service"

# ── Initial Super Admin Bootstrap ───────────────────────────
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_NAME="Platform Administrator"
INITIAL_ADMIN_PASSWORD=ChangeMe123!

# ── Trusted Proxies (set if behind load balancer) ────────────
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^(example\.com|.*\.example\.com)$'

# ── Federation Metadata URLs ─────────────────────────────────
# Comma-separated list of eduGAIN/SAFIRE/etc metadata aggregate URLs
FEDERATION_METADATA_URLS=https://metadata.edugain.org/edugain-v2.xml

# ── Local Port Overrides (optional) ─────────────────────────
HTTP_BIND=0.0.0.0
HTTPS_BIND=0.0.0.0
HTTP_PORT=80
HTTPS_PORT=443

# ── Monitoring ──────────────────────────────────────────────
# Optional: Sentry DSN for error tracking
SENTRY_DSN=
